    "emailjs-utf7": "^4.0.1",
    "express": "^4.17.1",
    "ts-node": "^10.9.1",
    "@types/express": "^4.17.13",
    "@types/node": "^17.0.45",
    "typescript": "^4.6.4",
    "valid-filename": "^3.1.0",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@types/eslint": "^8.4.2",
    "@typescript-eslint/eslint-plugin": "^5.25.0",
